{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Sazón Comunitario",
  "theme": "almond",
  "colors": {
    "primary": "#31582B",
    "light": "#B5D9B0",
    "dark": "#31582B"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/alcorher/entregable3_di"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/alcorher/entregable3_di"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart", "environment-setup"]
          },
          {
            "group": "Core Features",
            "pages": [
              "features/recipes",
              "features/user-profiles",
              "features/favorites",
              "features/search"
            ]
          },
          {
            "group": "Database",
            "pages": ["database/schema", "database/supabase-setup"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Authentication",
            "pages": ["api/auth/register", "api/auth/login"]
          },
          {
            "group": "Recipes",
            "pages": [
              "api/recipes/list",
              "api/recipes/detail",
              "api/recipes/user-recipes"
            ]
          },
          {
            "group": "Users & Profiles",
            "pages": ["api/users/list", "api/profiles/get", "api/profiles/update", "api/profiles/block"]
          },
          {
            "group": "Favorites & Uploads",
            "pages": ["api/favorites/list", "api/favorites/add", "api/favorites/delete", "api/upload"]
          }
        ]
      }
    ]
  }
}
